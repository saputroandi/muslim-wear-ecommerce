NODE_ENV=development
APP_NAME=Muslim Wear Ecommerce
APP_PORT=3000
APP_URL=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=muslim_wear
DB_USER=postgres
DB_PASSWORD=postgres
DB_SYNCHRONIZE=false

# Admin seed (used by scripts/seed-admin.ts)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Session
SESSION_SECRET=change-me-please

# Optional: override session table name used by connect-pg-simple
SESSION_TABLE_NAME=user_sessions

# Optional: session store debug logs (connect/disconnect/error)
SESSION_DEBUG=false

# Optional: cookie secure toggle.
# - true: always set cookie.secure
# - false: never set cookie.secure
# - empty: secure only in production
SESSION_COOKIE_SECURE=

# Optional: CSRF debug logs (prints session/token details)
CSRF_DEBUG=false
