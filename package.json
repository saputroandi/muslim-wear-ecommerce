    "@types/express": "^5.0.6",
    "@types/hbs": "^4.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.17",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
