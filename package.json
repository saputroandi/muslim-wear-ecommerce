    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "hbs": "^4.2.1",
    "joi": "^17.13.3",
    "pg": "^8.20.0",
