<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{appName}} - Product Form</title>
    <link rel="stylesheet" href="/css/design.css" />
  </head>
  <body>
    <header class="nav">
      <div class="container nav-inner">
        <a class="brand" href="/">{{appName}}</a>
        <nav class="nav-links">
          <a href="/products">Produk</a>
          <a href="/admin">Admin</a>
          <a href="/health">Health</a>
        </nav>
        <a class="pill-button secondary" href="/admin/products">Back to products</a>
      </div>
    </header>

    <main class="section container admin-shell">
      <div class="admin-toolbar">
        <div>
          <span class="badge">{{#if isEdit}}Edit mode{{else}}Create mode{{/if}}</span>
          <h1 class="section-title" style="margin-top:12px">{{title}}</h1>
          <p class="subtitle">{{intro}}</p>
        </div>
      </div>

      <article class="card section-card">
        <form method="post" action="{{action}}">
          <input type="hidden" name="_csrf" value="{{csrfToken}}" />
          <div class="admin-grid">
            <div class="form-group">
              <label class="form-label" for="name">Product name</label>
              <input class="form-input" id="name" name="name" type="text" value="{{product.name}}" required />
              <p class="helper-text">Nama yang tampil di katalog dan halaman detail.</p>
            </div>

            <div class="form-group">
              <label class="form-label" for="sku">SKU</label>
              <input class="form-input" id="sku" name="sku" type="text" value="{{product.sku}}" required />
              <p class="helper-text">Harus unik untuk produk utama.</p>
            </div>

            <div class="form-group">
              <label class="form-label" for="slug">Slug</label>
              <input class="form-input" id="slug" name="slug" type="text" value="{{product.slug}}" required />
              <p class="helper-text">Gunakan format URL-friendly, mis. gamis-premium.</p>
            </div>

            <div class="form-group">
              <label class="form-label" for="categoryId">Category</label>
              <select class="form-input" id="categoryId" name="categoryId" required>
                <option value="">Pilih kategori</option>
                {{#each categories}}
                  <option value="{{this.id}}" {{#if this.isSelected}}selected{{/if}}>{{this.name}}</option>
                {{/each}}
              </select>
              <p class="helper-text">Pilih kategori agar produk mudah difilter.</p>
            </div>

            <div class="form-group">
              <label class="form-label" for="basePriceCents">Base price (cents)</label>
              <input class="form-input" id="basePriceCents" name="basePriceCents" type="number" min="0" step="1" value="{{product.basePriceCents}}" required />
              <p class="helper-text">Format integer dalam satuan sen rupiah.</p>
            </div>

            <div class="form-group">
              <label class="form-label" for="imageUrl">Image URL</label>
              <input class="form-input" id="imageUrl" name="imageUrl" type="url" value="{{product.imageUrl}}" />
              <p class="helper-text">Opsional. Gunakan URL gambar produk yang valid.</p>
            </div>

            <div class="form-group" style="grid-column: 1 / -1">
              <label class="form-label" for="description">Description</label>
              <textarea class="form-input" id="description" name="description" rows="5">{{product.description}}</textarea>
              <p class="helper-text">Tulis manfaat dan detail produk secara ringkas.</p>
            </div>

            <div class="form-group">
              <label class="form-label" for="isActive">Status aktif</label>
              <select class="form-input" id="isActive" name="isActive" required>
                <option value="true" {{#if product.isActive}}selected{{/if}}>Active</option>
                <option value="false" {{#unless product.isActive}}selected{{/unless}}>Inactive</option>
              </select>
              <p class="helper-text">Inactive tidak tampil di katalog publik.</p>
            </div>
          </div>

          <div class="form-actions" style="margin-top:24px">
            <button class="pill-button primary" type="submit">{{submitLabel}}</button>
            <a class="pill-button secondary" href="/admin/products">Cancel</a>
          </div>
        </form>
      </article>
    </main>
  </body>
</html>
