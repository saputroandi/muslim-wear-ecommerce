<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{appName}} - Product Admin</title>
    <link rel="stylesheet" href="/css/design.css" />
  </head>
  <body>
    <header class="nav">
      <div class="container nav-inner">
        <a class="brand" href="/">{{appName}}</a>
        <nav class="nav-links">
          <a href="/products">Produk</a>
          <a href="/admin">Admin</a>
          <a href="/health">Health</a>
        </nav>
        <a class="pill-button secondary" href="/admin">Back to dashboard</a>
      </div>
    </header>

    <main class="section container admin-shell">
      <div class="admin-toolbar">
        <div>
          <span class="badge">Product management</span>
          <h1 class="section-title" style="margin-top:12px">{{title}}</h1>
          <p class="subtitle">{{intro}}</p>
        </div>
        <div class="admin-actions">
          <a class="pill-button primary" href="/admin/products/new">Tambah Produk</a>
          <a class="pill-button secondary" href="/admin/products">Refresh List</a>
        </div>
      </div>

      <article class="card section-card">
        <div class="pagination" style="margin-bottom:16px">
          <p class="helper-text">Total {{pagination.totalItems}} produk • halaman {{pagination.currentPage}} / {{pagination.totalPages}}</p>
          <div class="pagination-links">
            {{#if pagination.hasPreviousPage}}
              <a class="pagination-link" href="/admin/products?page={{pagination.previousPage}}&limit={{pagination.limit}}">Previous</a>
            {{/if}}
            <span class="pagination-link is-active">{{pagination.currentPage}}</span>
            {{#if pagination.hasNextPage}}
              <a class="pagination-link" href="/admin/products?page={{pagination.nextPage}}&limit={{pagination.limit}}">Next</a>
            {{/if}}
          </div>
        </div>

        {{#if products.length}}
          <div class="table-shell">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Category</th>
                  <th>Price</th>
                  <th>Variants</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {{#each products}}
                  <tr>
                    <td>
                      <strong>{{this.name}}</strong><br />
                      <span class="helper-text">{{this.sku}}</span><br />
                      <span class="helper-text">{{this.slug}}</span>
                    </td>
                    <td>{{this.categoryName}}</td>
                    <td>{{this.basePriceLabel}}</td>
                    <td>{{this.variantsCount}}</td>
                    <td>
                      {{#if this.isActive}}
                        <span class="status-pill success">{{this.statusLabel}}</span>
                      {{else}}
                        <span class="status-pill danger">{{this.statusLabel}}</span>
                      {{/if}}
                    </td>
                    <td>
                      <div class="table-actions">
                        <a class="pill-button secondary" href="/admin/products/{{this.id}}/edit">Edit</a>
                        <a class="pill-button secondary" href="/admin/products/{{this.id}}/variants">Variants</a>
                        <form method="post" action="/admin/products/{{this.id}}/delete">
                          <input type="hidden" name="_csrf" value="{{../csrfToken}}" />
                          <button class="pill-button danger" type="submit">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{else}}
          <div class="empty-state">
            <p class="section-title" style="font-size: 28px; margin-bottom: 12px">Belum ada produk</p>
            <p class="helper-text">Buat produk pertama untuk mulai mengisi katalog.</p>
            <div style="margin-top:20px">
              <a class="pill-button primary" href="/admin/products/new">Tambah Produk</a>
            </div>
          </div>
        {{/if}}
      </article>
    </main>
  </body>
</html>
