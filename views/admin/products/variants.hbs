<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{appName}} - Product Variants</title>
    <link rel="stylesheet" href="/css/design.css" />
  </head>
  <body>
    <header class="nav">
      <div class="container nav-inner">
        <a class="brand" href="/">{{appName}}</a>
        <nav class="nav-links">
          <a href="/products">Produk</a>
          <a href="/admin">Admin</a>
          <a href="/health">Health</a>
        </nav>
        <a class="pill-button secondary" href="/admin/products">Back to products</a>
      </div>
    </header>

    <main class="section container admin-shell">
      <div class="admin-toolbar">
        <div>
          <span class="badge">Variant management</span>
          <h1 class="section-title" style="margin-top:12px">{{title}}</h1>
          <p class="subtitle">{{intro}}</p>
        </div>
        <div class="admin-actions">
          <a class="pill-button primary" href="/admin/products/{{product.id}}/edit">Edit Product</a>
        </div>
      </div>

      <article class="card section-card">
        <h2 class="section-title" style="font-size: 28px; margin-bottom: 12px">{{product.name}}</h2>
        <p class="helper-text">SKU utama: {{product.sku}} • Kategori: {{product.categoryName}} • Harga dasar: {{product.basePriceLabel}}</p>
        <p class="helper-text">Variant total: {{variantCount}}</p>
      </article>

      <article class="card section-card">
        <div class="admin-toolbar" style="margin-bottom: 16px">
          <div>
            <h2 class="section-title" style="font-size: 28px; margin-bottom: 8px">Add variant</h2>
            <p class="helper-text">Tambahkan varian baru dengan size, warna, SKU, dan stok awal.</p>
          </div>
        </div>

        <form method="post" action="/admin/products/{{product.id}}/variants">
          <input type="hidden" name="_csrf" value="{{csrfToken}}" />
          <datalist id="variant-sizes">
            {{#each variantSizes}}
              <option value="{{this}}"></option>
            {{/each}}
          </datalist>
          <div class="admin-grid">
            <div class="form-group">
              <label class="form-label" for="size">Size</label>
              <input class="form-input" id="size" name="size" type="text" placeholder="M" list="variant-sizes" />
              <p class="helper-text">Gunakan XS, S, M, L, XL, atau XXL.</p>
            </div>
            <div class="form-group">
              <label class="form-label" for="color">Color</label>
              <input class="form-input" id="color" name="color" type="text" placeholder="Black" />
            </div>
            <div class="form-group">
              <label class="form-label" for="sku">SKU</label>
              <input class="form-input" id="sku" name="sku" type="text" placeholder="HIJAB-001-BLK-M" />
            </div>
            <div class="form-group">
              <label class="form-label" for="stock">Stock</label>
              <input class="form-input" id="stock" name="stock" type="number" min="0" step="1" value="0" />
            </div>
            <div class="form-group">
              <label class="form-label" for="reserved">Reserved</label>
              <input class="form-input" id="reserved" name="reserved" type="number" min="0" step="1" value="0" />
            </div>
            <div class="form-group">
              <label class="form-label" for="variantPriceCents">Variant price (cents)</label>
              <input class="form-input" id="variantPriceCents" name="variantPriceCents" type="number" min="0" step="1" value="" />
            </div>
          </div>
          <div class="form-actions" style="margin-top: 24px">
            <button class="pill-button primary" type="submit">Add Variant</button>
          </div>
        </form>
      </article>

      <article class="card section-card">
        <div class="admin-toolbar" style="margin-bottom: 16px">
          <div>
            <h2 class="section-title" style="font-size: 28px; margin-bottom: 8px">Existing variants</h2>
            <p class="helper-text">Edit langsung dari kartu varian atau hapus jika tidak dipakai lagi.</p>
          </div>
        </div>

        {{#if variants.length}}
          <div class="admin-grid">
            {{#each variants}}
              <article class="card" style="padding: 16px">
                <div class="admin-toolbar" style="margin-bottom: 14px">
                  <div>
                    <h3 style="margin: 0 0 4px">{{this.sku}}</h3>
                    <p class="helper-text">Variant price: {{this.variantPriceLabel}}</p>
                  </div>
                  <span class="status-pill neutral">{{this.size}} • {{this.color}}</span>
                </div>

                <form method="post" action="/admin/products/variants/{{this.id}}">
                  <input type="hidden" name="_csrf" value="{{../csrfToken}}" />
                  <div class="form-grid">
                    <div class="form-group">
                      <label class="form-label" for="size-{{this.id}}">Size</label>
                      <input class="form-input" id="size-{{this.id}}" name="size" type="text" value="{{this.size}}" list="variant-sizes" />
                    </div>
                    <div class="form-group">
                      <label class="form-label" for="color-{{this.id}}">Color</label>
                      <input class="form-input" id="color-{{this.id}}" name="color" type="text" value="{{this.color}}" />
                    </div>
                    <div class="form-group">
                      <label class="form-label" for="sku-{{this.id}}">SKU</label>
                      <input class="form-input" id="sku-{{this.id}}" name="sku" type="text" value="{{this.sku}}" />
                    </div>
                    <div class="form-group">
                      <label class="form-label" for="stock-{{this.id}}">Stock</label>
                      <input class="form-input" id="stock-{{this.id}}" name="stock" type="number" min="0" step="1" value="{{this.stock}}" />
                    </div>
                    <div class="form-group">
                      <label class="form-label" for="reserved-{{this.id}}">Reserved</label>
                      <input class="form-input" id="reserved-{{this.id}}" name="reserved" type="number" min="0" step="1" value="{{this.reserved}}" />
                    </div>
                    <div class="form-group">
                      <label class="form-label" for="variantPriceCents-{{this.id}}">Variant price (cents)</label>
                      <input class="form-input" id="variantPriceCents-{{this.id}}" name="variantPriceCents" type="number" min="0" step="1" value="{{this.variantPriceCents}}" />
                    </div>
                  </div>
                  <div class="row-actions" style="margin-top: 16px">
                    <button class="pill-button primary" type="submit">Update</button>
                  </div>
                </form>

                <form method="post" action="/admin/products/variants/{{this.id}}/delete" style="margin-top: 12px">
                  <input type="hidden" name="_csrf" value="{{../csrfToken}}" />
                  <button class="pill-button danger" type="submit">Delete variant</button>
                </form>
              </article>
            {{/each}}
          </div>
        {{else}}
          <div class="empty-state">
            <p class="section-title" style="font-size: 28px; margin-bottom: 12px">Belum ada varian</p>
            <p class="helper-text">Tambahkan varian pertama dari form di atas.</p>
          </div>
        {{/if}}
      </article>
    </main>
  </body>
</html>
