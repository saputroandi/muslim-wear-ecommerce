<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password</title>
    <link rel="stylesheet" href="/css/design.css" />
  </head>
  <body>
    <main class="container auth-shell">
      <section class="card auth-card">
        <div class="auth-header">
          <p class="badge auth-kicker">Secure reset</p>
          <h1 class="section-title auth-title">Reset Password</h1>
          <p class="field-hint">Buat password baru untuk melanjutkan akses admin.</p>
        </div>

      {{#if error}}
        <div class="alert alert-error" role="alert">{{error}}</div>
      {{/if}}
        <form class="auth-form" method="post" action="/auth/reset-password">
          <input type="hidden" name="_csrf" value="{{csrfToken}}" />
          <input type="hidden" name="token" value="{{token}}" />
          <input type="hidden" name="email" value="{{email}}" />
          <div class="form-group">
            <label class="form-label" for="password">Password Baru</label>
            <input class="form-input" id="password" name="password" type="password" required autocomplete="new-password" />
          </div>
          <div class="form-actions">
            <button class="pill-button primary" type="submit">Reset Password</button>
          </div>
        </form>
      </section>
    </main>
  </body>
</html>
