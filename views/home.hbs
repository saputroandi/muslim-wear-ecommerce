<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}} | {{siteName}}</title>
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">Express MVC starter</p>
        <h1>{{siteName}}</h1>
        <p class="lead">
          Fondasi baru yang ringan, rapi, dan siap dikembangkan dari nol.
        </p>
        <div class="actions">
          <a class="button" href="/products">Lihat produk</a>
          <a class="button button-secondary" href="/health">Health check</a>
        </div>
      </section>

      <section class="card-grid">
        {{#each featuredProducts}}
          <article class="card">
            <p class="card-title">{{name}}</p>
            <p class="card-price">{{price}}</p>
            <p class="card-copy">{{description}}</p>
          </article>
        {{/each}}
      </section>
    </main>
  </body>
</html>
