<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{appName}} - Produk</title>
    <link rel="stylesheet" href="/css/design.css" />
  </head>
  <body>
    <header class="nav">
      <div class="container nav-inner">
        <a class="brand" href="/">{{appName}}</a>
        <nav class="nav-links">
          <a href="/products">Produk</a>
          <a href="/admin">Admin</a>
          <a href="/health">Health</a>
        </nav>
        <a class="pill-button secondary" href="/">Kembali</a>
      </div>
    </header>

    <main class="section container">
      <span class="badge">Catalog preview</span>
      <h1 class="section-title">Katalog Produk (Starter)</h1>
      <p class="subtitle">Halaman ini baru menampilkan contoh data. Fitur filter/search/variant akan diimplementasikan pada phase roadmap.</p>
      <div class="cards">
        {{#each featuredProducts}}
          <article class="card">
            <p class="badge">{{this.category}}</p>
            <h3>{{this.name}}</h3>
            <p class="muted">{{this.priceLabel}}</p>
          </article>
        {{/each}}
      </div>
    </main>
  </body>
</html>
